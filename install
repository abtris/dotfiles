#!/bin/sh
set -u

root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
status=0

link() {
  source=$root/$1
  target=$HOME/$2

  if [ ! -e "$source" ]; then
    printf 'missing  %s\n' "$source" >&2
    status=1
  elif [ -L "$target" ] && [ "$(readlink "$target")" = "$source" ]; then
    printf 'ok       %s\n' "$target"
  elif [ -e "$target" ] || [ -L "$target" ]; then
    printf 'conflict %s (move it aside and rerun)\n' "$target" >&2
    status=1
  else
    if mkdir -p "$(dirname -- "$target")" && ln -s "$source" "$target"; then
      printf 'linked   %s\n' "$target"
    else
      status=1
    fi
  fi
}

seed() {
  source=$root/$1
  target=$HOME/$2

  if [ -e "$target" ] || [ -L "$target" ]; then
    printf 'ok       %s\n' "$target"
  elif mkdir -p "$(dirname -- "$target")" && cp "$source" "$target"; then
    printf 'copied   %s\n' "$target"
  else
    status=1
  fi
}

while IFS='|' read -r source target; do
  link "$source" "$target"
done <<'EOF'
zshrc-ohmyzsh|.zshrc
bashrc|.bashrc
zlogout|.zlogout
git/.gitconfig|.gitconfig
git/.gitignore|.gitignore
git/.gittemplate|.gittemplate
git/.git-commit-template.txt|.git-commit-template.txt
.ackrc|.ackrc
.cobra.yaml|.cobra.yaml
.curlrc|.curlrc
.gemrc|.gemrc
.hgignore|.hgignore
.nanorc|.nanorc
.prettierrc|.prettierrc
.screenrc|.screenrc
.tldrrc|.tldrrc
.tmux.conf|.tmux.conf
.vim|.vim
vimrc|.vimrc
vimpluginrc|.vimpluginrc
coffeelint.json|coffeelint.json
atuin/config.toml|.config/atuin/config.toml
.config/bat/config|.config/bat/config
ghostty/config|.config/ghostty/config
ghostty/themes/catppuccin-mocha.conf|.config/ghostty/themes/catppuccin-mocha.conf
helix/config.toml|.config/helix/config.toml
hunk/config.toml|.config/hunk/config.toml
lsd/colors.yaml|.config/lsd/colors.yaml
lsd/config.yaml|.config/lsd/config.yaml
mise/config.toml|.config/mise/config.toml
zellij/config.kdl|.config/zellij/config.kdl
wezterm/wezterm.lua|.wezterm.lua
k9s/plugins.yaml|Library/Application Support/k9s/plugins.yaml
vscode/settings.json|Library/Application Support/Code/User/settings.json
themes/abtris.zsh-theme|.oh-my-zsh/custom/themes/abtris.zsh-theme
custom/plugins/abtris|.oh-my-zsh/custom/plugins/abtris
EOF

seed mc/ini .config/mc/ini

exit "$status"
